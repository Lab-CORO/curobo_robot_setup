           <width>20</width>
           <height>40</height>
          </size>
         </property>
        </spacer>
       </item>
       <item>
        <widget class="QLabel" name="label_urdf_help">
         <property name="text">
          <string>&lt;html&gt;&lt;b&gt;Next steps:&lt;/b&gt;&lt;br/&gt;
1. Add RobotModel display in RViz&lt;br/&gt;
2. Go to Sphere Editor tab&lt;br/&gt;
3. Select links and add collision spheres&lt;br/&gt;
4. Go to Configuration tab&lt;br/&gt;
5. Save to YAML file&lt;/html&gt;</string>
         </property>
         <property name="wordWrap">
          <bool>true</bool>
         </property>
         <property name="textFormat">
          <enum>Qt::RichText</enum>
         </property>
        </widget>
       </item>
      </layout>
     </widget>
     
     <!-- ============================================ -->
     <!-- TAB 2: Sphere Editor -->
     <!-- ============================================ -->
     <widget class="QWidget" name="sphere_editor">
      <attribute name="title">
       <string>2. Sphere Editor</string>
      </attribute>
      <layout class="QVBoxLayout" name="verticalLayout_spheres">
       
       <!-- Robot Links Tree -->
       <item>
        <widget class="QGroupBox" name="groupBox_links">
         <property name="title">
          <string>Select Robot Link</string>
         </property>
         <layout class="QVBoxLayout" name="verticalLayout_links">
          <item>
           <widget class="QTreeWidget" name="treeWidget_links">
            <property name="maximumHeight">
             <number>150</number>
            </property>
            <property name="alternatingRowColors">
