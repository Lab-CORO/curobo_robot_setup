          </item>
          <item row="2" column="3">
           <widget class="QDoubleSpinBox" name="doubleSpinBox_y">
            <property name="decimals">
             <number>4</number>
            </property>
            <property name="minimum">
             <double>-2.0</double>
            </property>
            <property name="maximum">
             <double>2.0</double>
            </property>
            <property name="singleStep">
